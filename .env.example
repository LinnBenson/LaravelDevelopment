# APP 信息
APP_NAME=TestName
APP_ENV=local
APP_KEY=base64:JkvUss3Nb1ekliUqeRYFqhG2mbdi9qAagGz0eFUH3Qg=
APP_DEBUG=true
APP_URL=http://mac.io
APP_ADMIN_PREFIX=admin
APP_TIMEZONE=Asia/Singapore
VITE_APP_NAME="${APP_NAME}"
# 语言设置
APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en-US
# 维护模式
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
# 日志配置
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DAILY_DAYS=3
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# 数据库配置
DB_PREFIX="${APP_NAME}_"
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=laravel
# Session 配置
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# 广播及驱动
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Memcached 配置
MEMCACHED_HOST=127.0.0.1
# Redis 配置
REDIS_PREFIX="${APP_NAME}_"
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# 邮箱 SMTP 配置
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# AWS 配置
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
# 其它设置
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12
CACHE_STORE=file
